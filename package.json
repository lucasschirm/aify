{
  "name": "@lucasschirm/aify",
  "version": "1.0.0",
  "description": "A tiny cli command to get ServiceNow records locally with merge/conflict structure.",
  "keywords": [
    "servicenow",
    "cli",
    "application",
    "sync"
  ],
  "homepage": "https://github.com/lucasschirm/aify#readme",
  "bugs": {
    "url": "https://github.com/lucasschirm/aify/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasschirm/aify.git"
  },
  "license": "ISC",
  "author": "Lucas Caixeta",
  "type": "commonjs",
  "main": "dist/main.js",
  "bin": {
    "aify": "dist/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:template-db": "tsx scripts/build-template-db.ts",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/test",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "verify": "pnpm lint && pnpm test && pnpm test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "keytar": "^7.9.0",
    "nest-commander": "^3.20.1",
    "ora": "5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "safe-merge-files": "^0.2.3",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^6.0.1",
    "xxhash-addon": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "biome format --write",
    "*.{ts,js}": "biome lint --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "commander": "11.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nest-commander-testing": "^3.5.1",
    "nock": "^14.0.16",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10"
  }
}
